{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lucas Desktop",
  "version": "0.1.0",
  "identifier": "com.lucas.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lucas Desktop",
        "width": 1920,
        "height": 1080,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "wix": null,
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
